# Local development environment template.
# Copy to .env and source it, or export the variables in your shell.
# (On Render these are set in the dashboard / render.yaml instead.)

# Required in production; optional locally when DEBUG=true
SECRET_KEY=

# true for local development, false in production
DEBUG=true

# Comma-separated. Leave empty locally (defaults to localhost).
ALLOWED_HOSTS=

# Neon Postgres connection string. Leave empty locally to use SQLite.
DATABASE_URL=

# Vector classifier
CLASSIFIER_ENABLED=true
CLASSIFIER_THRESHOLD=0.35
CLASSIFIER_TOP_K=3
TRIGGER_FALLBACK_ENABLED=true

# Contact shown in templates
ADMIN_EMAIL=
